{
  "compilerOptions": {
    // Target modern Node.js — ES2022 gives us top-level await, structuredClone, etc.
    "target": "ES2022",

    // NodeNext: correct ESM interop for Node.js >= 16
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    // Strict mode — catches null/undefined issues at compile time (critical for compliance code)
    "strict": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,

    // Output
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,

    // Interop helpers — needed for mixing CJS/ESM packages
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    // Keep imports clean
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    // Make unused variables a hard error — prevents dead evidence-ledger code
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
