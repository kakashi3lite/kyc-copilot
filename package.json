{
  "name": "kyc-copilot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Agentic AML/KYC compliance platform for EU payments institutions.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed.ts",
    "demo": "docker compose up -d db redis && npm run db:migrate && npm run db:seed && npm run dev",
    "launch": "tsx scripts/launch.ts"
  },
  "dependencies": {
    "@hono/node-server": "1.13.8",
    "@langchain/anthropic": "^0.3.12",
    "@langchain/core": "^0.3.58",
    "@langchain/google-genai": "^0.1.8",
    "@langchain/langgraph": "0.2.39",
    "@langchain/langgraph-checkpoint-postgres": "1.0.1",
    "@langchain/ollama": "^0.1.4",
    "@langchain/openai": "^0.4.1",
    "@types/boxen": "^2.1.0",
    "@types/chalk": "^0.4.31",
    "@types/ora": "^3.1.0",
    "@types/prompts": "^2.4.9",
    "bcrypt": "5.1.1",
    "boxen": "^8.0.1",
    "bullmq": "5.34.7",
    "chalk": "^5.6.2",
    "date-fns-tz": "3.2.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "0.38.4",
    "envalid": "8.0.0",
    "hono": "4.6.20",
    "ioredis": "5.4.2",
    "jsonwebtoken": "9.0.2",
    "node-fetch": "^3.3.2",
    "ora": "^9.4.0",
    "pg": "8.13.1",
    "pg-pool": "3.7.0",
    "pino": "9.6.0",
    "playwright": "1.49.1",
    "prompts": "^2.4.2",
    "puppeteer": "23.11.1",
    "resend": "4.1.2",
    "stripe": "17.5.0",
    "uuid": "11.0.5",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "5.0.2",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "22.10.6",
    "@types/pg": "8.11.10",
    "@vitest/coverage-v8": "2.1.8",
    "drizzle-kit": "0.30.2",
    "jsdom": "25.0.1",
    "msw": "2.7.0",
    "supertest": "7.0.0",
    "testcontainers": "10.17.2",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "2.1.8"
  }
}
